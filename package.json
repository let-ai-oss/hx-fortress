{
  "name": "hx-fortress",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "bin": {
    "hx-fortress": "./src/cli.ts"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun --watch src/cli.ts",
    "build": "mkdir -p ./dist && bun build ./src/cli.ts --compile --outfile ./dist/hx-fortress",
    "install-local": "bun run build && cp ./dist/hx-fortress $HOME/.let/bin/hx-fortress",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:check": "drizzle-kit check",
    "check": "bun run typecheck && bun run lint && bun run db:check && bun test"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.14",
    "drizzle-kit": "^0.31.10",
    "eslint": "10.5.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@google-cloud/storage": "^7.21.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3"
  }
}
